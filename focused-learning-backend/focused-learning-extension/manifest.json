{
  "manifest_version": 3,
  "name": "ZoneIn",
  "version": "1.1",
  "description": "Transform YouTube into a distraction-free learning platform.",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "windows"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "http://localhost:5000/*",
    "http://localhost:5174/*",
    "https://your-deployed-backend.com/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ZoneIn",
    "default_icon": "icons/icon48.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["api.js"],
      "matches": ["<all_urls>"]
    }
  ]
}